#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export CARGO_HOME = $(CURDIR)/debian/cargo

%:
	dh $@

override_dh_auto_clean:
	cargo clean --manifest-path src/Cargo.toml || true
	rm -rf $(CARGO_HOME)

override_dh_auto_configure:
	mkdir -p $(CARGO_HOME)
	bash packaging/linux/generate-icons.sh assets/icons/icon.png

override_dh_auto_build:
	cargo build --release --manifest-path src/Cargo.toml

override_dh_auto_test:
	# Skip tests for now (require display server)
	true

override_dh_auto_install:
	install -Dm755 src/target/release/linux-soundboard \
		debian/linux-soundboard/usr/bin/linux-soundboard
	
	# Install desktop file
	install -Dm644 packaging/debian/linux-soundboard.desktop \
		debian/linux-soundboard/usr/share/applications/com.linuxsoundboard.app.desktop
	
	# Install icons
	for size in 16x16 24x24 32x32 48x48 64x64 128x128 256x256 512x512; do \
		install -Dm644 src/resources/icons/$$size/apps/com.linuxsoundboard.app.png \
			debian/linux-soundboard/usr/share/icons/hicolor/$$size/apps/com.linuxsoundboard.app.png; \
		install -Dm644 src/resources/icons/$$size/apps/linux-soundboard.png \
			debian/linux-soundboard/usr/share/icons/hicolor/$$size/apps/linux-soundboard.png; \
	done
	
	# Install metainfo
	install -Dm644 packaging/flatpak/com.linuxsoundboard.app.metainfo.xml \
		debian/linux-soundboard/usr/share/metainfo/com.linuxsoundboard.app.metainfo.xml

	# Install one-click Wayland hotkey installer helper and policy
	install -Dm755 packaging/linux/install-swhkd-helper.sh \
		debian/linux-soundboard/usr/libexec/linux-soundboard/install-swhkd-helper.sh
	install -Dm644 packaging/linux/com.linuxsoundboard.install-swhkd.policy \
		debian/linux-soundboard/usr/share/polkit-1/actions/com.linuxsoundboard.install-swhkd.policy
